{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "Bash(php:*)",
      "Bash(composer:*)",
      "Bash(npm:*)",
      "Bash(echo:*)",
      "Bash(vendor/bin/pint:*)",
      "Bash(where:*)",
